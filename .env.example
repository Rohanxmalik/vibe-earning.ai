DATABASE_URL=postgresql://kbi:kbi@localhost:5432/kbi?schema=public
REDIS_URL=redis://localhost:6379
ADMIN_API_KEY=dev-admin-key-change-me
PORT=3000
AUTH_JWT_SECRET=dev-jwt-secret-change-me
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# --- Payment providers ---
# Leave the keys unset in dev: adapters throw a clear "*_not_configured" error
# and tests inject fakes. Set real values in prod.
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RazorpayX (developer payouts) — virtual account number that funds payouts.
RAZORPAYX_ACCOUNT_NUMBER=
# Webhook signing secrets (used to verify inbound PSP webhooks).
RAZORPAY_WEBHOOK_SECRET=dev-razorpay-webhook-secret
STRIPE_WEBHOOK_SECRET=dev-stripe-webhook-secret

# --- Fraud / metrics knobs (optional; defaults shown) ---
# FRAUD_IP_SALT=change-me-in-prod
# FRAUD_IP_MAX_INSTALLS=5
# FRAUD_IP_WINDOW_SEC=3600
# METRICS_MIN_VIEW_MS=5000
# METRICS_MIN_GAP_MS=5000
# METRICS_HOURLY_CAP=120
# METRICS_DAILY_CAP=600
# PAYOUT_MIN_PAISE=10000

# --- Email (transactional: verification, password reset, payout notices) ---
# Unset ⇒ emails are logged, not sent (dev). Set to send via Resend (or swap the adapter).
# RESEND_API_KEY=
# EMAIL_FROM=Kickbacks <noreply@kickbacks.in>
# PORTAL_BASE_URL=http://localhost:3001   # base URL used in emailed links

# --- Fraud sweep (optional) ---
# FRAUD_SWEEP_INTERVAL_MS=0   # >0 enables a periodic auto-void of over-threshold IP clusters

# --- Portal (build-time) ---
NEXT_PUBLIC_API_BASE=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3001   # absolute URL for OG/social metadata
