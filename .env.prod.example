# Production environment template — copy to `.env` next to docker-compose.prod.yml
# (or load into your host's secret manager). NEVER commit the filled-in file.
# Generate strong secrets:  openssl rand -hex 32

# --- Core (required) ---
POSTGRES_USER=kbi
POSTGRES_PASSWORD=__CHANGE_ME__strong-random__
POSTGRES_DB=kbi
# If using a MANAGED Postgres/Redis (recommended), set these to the provider URLs
# instead of relying on the bundled containers:
# DATABASE_URL=postgresql://user:pass@your-managed-host:5432/kbi?schema=public
# REDIS_URL=rediss://user:pass@your-managed-redis:6379
AUTH_JWT_SECRET=__CHANGE_ME__openssl-rand-hex-32__
ADMIN_API_KEY=__CHANGE_ME__break-glass-only__

# --- Auth ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# --- Payments (from each provider dashboard — see docs/launch/PAYMENTS_SETUP.md) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# --- Email (transactional) ---
RESEND_API_KEY=
EMAIL_FROM=Kickbacks <noreply@your-domain.com>
PORTAL_BASE_URL=https://your-portal-domain.com

# --- Hardening (set in prod) ---
FRAUD_IP_SALT=__CHANGE_ME__random__
FRAUD_SWEEP_INTERVAL_MS=0          # >0 enables periodic auto-void of fraud clusters
CORS_ORIGINS=https://your-portal-domain.com
SENTRY_DSN=
LOG_LEVEL=info
THROTTLE_LIMIT=300

# --- Money knobs (optional; defaults shown) ---
# PAYOUT_MIN_PAISE=10000          # ₹100 minimum withdrawal
# LEDGER_DEV_SHARE_BPS=5000       # 50% developer revenue share

# --- Portal (build-time, baked into the image) ---
NEXT_PUBLIC_API_BASE=https://your-api-domain.com
