generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id        String   @id @default(cuid())
  copy      String
  url       String
  iconUrl   String?
  isHouseAd Boolean  @default(false)
  status    String   @default("active")
  bids      Bid[]
  createdAt DateTime @default(now())
}

model Bid {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  surface    String
  amount     Int
  status     String   @default("active")
  createdAt  DateTime @default(now())

  @@index([surface, status])
}

model Account {
  id        String    @id @default(cuid())
  type      String    @default("dev") // dev | advertiser | admin
  email     String?
  oauthSub  String?   @unique
  country   String?
  createdAt DateTime  @default(now())
  events    AdEvent[]
}

model AdEvent {
  id         String   @id @default(cuid())
  installId  String
  campaignId String
  surface    String
  type       String   // impression | click
  nonce      String
  visibleMs  Int      @default(0)
  valid      Boolean
  reason     String?  // view_too_short | spacing | hourly_cap | daily_cap ; null when valid
  createdAt  DateTime @default(now())
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id])

  @@unique([installId, nonce])
  @@index([campaignId, type, valid])
}

model LedgerEntry {
  id        String   @id @default(cuid())
  eventId   String   // the AdEvent that caused this entry (idempotency key)
  account   String   // ledger account key, e.g. escrow:campaign:<id> | earnings:dev:<id> | revenue:platform
  direction String   // debit | credit
  amount    Int      // paise, always positive
  currency  String   @default("INR")
  createdAt DateTime @default(now())

  @@unique([eventId, account, direction])
  @@index([account])
}
