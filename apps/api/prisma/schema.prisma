generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id        String   @id @default(cuid())
  copy      String
  url       String
  iconUrl   String?
  isHouseAd Boolean  @default(false)
  status    String   @default("active")
  pacePerMinute Int?  // optional delivery cap: max impressions served per minute (null = unlimited)
  bids      Bid[]
  createdAt DateTime @default(now())
  advertiserId String?
  advertiser   Account?        @relation(fields: [advertiserId], references: [id])
  purchases    BlockPurchase[]
}

model Bid {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  surface    String
  amount     Int
  status     String   @default("active")
  createdAt  DateTime @default(now())

  @@index([surface, status])
}

model Account {
  id        String    @id @default(cuid())
  type      String    @default("dev") // dev | advertiser | admin
  email     String?
  emailVerified Boolean @default(false)
  oauthSub  String?   @unique
  country   String?
  createdAt DateTime  @default(now())
  suspended Boolean   @default(false)
  passwordHash String?
  events    AdEvent[]
  payouts   Payout[]
  campaigns Campaign[]
  payoutDestinations PayoutDestination[]

  // One account per email per role (NULL emails — e.g. some OAuth users — stay distinct).
  @@unique([email, type])
}

model PayoutDestination {
  id            String   @id @default(cuid())
  account       Account  @relation(fields: [accountId], references: [id])
  accountId     String
  method        String   // upi | bank
  vpa           String?  // UPI VPA (method=upi)
  accountNumber String?  // bank account (method=bank)
  ifsc          String?  // bank IFSC (method=bank)
  status        String   @default("pending") // pending | verified | rejected
  providerRef   String?  // RazorpayX fund_account id once created during KYC
  createdAt     DateTime @default(now())

  @@index([accountId])
}

model AdEvent {
  id         String   @id @default(cuid())
  installId  String
  campaignId String
  surface    String
  type       String   // impression | click
  nonce      String
  visibleMs  Int      @default(0)
  valid      Boolean
  reason     String?  // view_too_short | spacing | hourly_cap | daily_cap | ip_cluster ; null when valid
  ipHash     String?  // server-derived salted hash of source IP; used for fraud clustering
  createdAt  DateTime @default(now())
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id])

  @@unique([installId, nonce])
  @@index([campaignId, type, valid])
  @@index([ipHash])
}

model LedgerEntry {
  id        String   @id @default(cuid())
  eventId   String   // the AdEvent that caused this entry (idempotency key)
  account   String   // ledger account key, e.g. escrow:campaign:<id> | earnings:dev:<id> | revenue:platform
  direction String   // debit | credit
  amount    Int      // paise, always positive
  currency  String   @default("INR")
  createdAt DateTime @default(now())

  @@unique([eventId, account, direction])
  @@index([account])
}

model Payout {
  id          String   @id @default(cuid())
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   String
  provider    String   // stripe | razorpay
  amountPaise Int
  currency    String   @default("INR")
  status      String   // paid | pending | failed
  providerRef String?
  createdAt   DateTime @default(now())

  @@index([accountId])
}

model BlockPurchase {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  quantity    Int
  amountPaise Int
  currency    String   @default("INR")
  status      String   // paid | pending | failed
  providerRef String?
  createdAt   DateTime @default(now())

  @@index([campaignId])
}

model Killswitch {
  id        String   @id @default(cuid())
  scope     String   @unique
  active    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
