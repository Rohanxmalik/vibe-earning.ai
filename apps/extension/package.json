{
  "name": "vibearning",
  "displayName": "vibearning",
  "description": "Earn for the sponsored line shown while your AI coding agent thinks. Paid to Indian developers via UPI.",
  "version": "0.1.0",
  "publisher": "vibearning",
  "license": "SEE LICENSE IN LICENSE",
  "categories": ["Other"],
  "keywords": ["ai", "claude", "codex", "gemini", "earn", "ads"],
  "repository": { "type": "git", "url": "https://github.com/Rohanxmalik/vibe-earning.ai.git" },
  "homepage": "https://github.com/Rohanxmalik/vibe-earning.ai#readme",
  "galleryBanner": { "color": "#18181b", "theme": "dark" },
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.90.0" },
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "vibearning", "title": "vibearning", "icon": "media/vibearning.svg" }
      ]
    },
    "views": {
      "vibearning": [
        { "type": "webview", "id": "vibearning.adView", "name": "Earnings & Sponsor" }
      ]
    },
    "commands": [
      { "command": "vibearning.signIn", "title": "vibearning: Sign in" },
      { "command": "vibearning.signOut", "title": "vibearning: Sign out" },
      { "command": "vibearning.openSponsor", "title": "vibearning: Open the current sponsor" },
      { "command": "vibearning.openDashboard", "title": "vibearning: Open your earnings dashboard" }
    ],
    "configuration": {
      "title": "vibearning",
      "properties": {
        "vibearning.apiUrl": {
          "type": "string",
          "default": "https://api.vibearning.in",
          "markdownDescription": "Base URL of the vibearning API. Change this only if you self-host. (Overridden by the `VIBEARNING_API` environment variable when set.)"
        },
        "vibearning.portalUrl": {
          "type": "string",
          "default": "https://vibearning.in",
          "markdownDescription": "Base URL of the vibearning web dashboard opened by the earnings item. (Overridden by the `VIBEARNING_PORTAL` environment variable when set.)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "vscode:prepublish": "node esbuild.mjs",
    "package": "vsce package --no-dependencies -o vibearning.vsix"
  },
  "devDependencies": {
    "@vibearning/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
