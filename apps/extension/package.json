{
  "name": "@kbi/extension",
  "displayName": "Kickbacks-India",
  "version": "0.0.0",
  "private": true,
  "engines": { "vscode": "^1.90.0" },
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "kickbacks.simulateWait", "title": "Kickbacks: Simulate Wait-State (dev)" },
      { "command": "kickbacks.endWait", "title": "Kickbacks: End Wait-State (dev)" },
      { "command": "kickbacks.signIn", "title": "Kickbacks: Sign in (dev: paste Google ID token)" }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@kbi/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
